<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:fitsSystemWindows="true">

    <EditText android:id="@+id/editName" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Pest/Disease Name"/>
    <EditText android:id="@+id/editSymptoms" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Symptoms"/>
    <EditText android:id="@+id/editTreatment" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Treatment"/>
    <Button android:id="@+id/btnSavePest" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Save"/>
    <TextView android:id="@+id/txtData" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="16sp"/>

    <ImageView
        android:layout_width="300dp"
        android:layout_height="300dp"
        android:layout_gravity="center"
        android:src="@drawable/pest" />

</LinearLayout>
